        <script><![CDATA[function onSubmit() {
    var id = g_form.getValue('user_id');

    var plugDetails = new GlideAjax('AJAXUtils');
    plugDetails.addParam('sysparm_name', 'checkUserID');
    plugDetails.addParam('sysparm_sys_id', id);
    plugDetails.getXMLAnswer(userCheck);

    function userCheck(response) {
        if (response) {
            var parsedData = JSON.parse(response);
            var userID = parsedData.ci;
            //g_form.setValue('cmdb_ci', '');
            g_form.addErrorMessage('User with ID (' + userID + ') already exsits.', 'error');
			return false;
        }
    }

}]]></script>
