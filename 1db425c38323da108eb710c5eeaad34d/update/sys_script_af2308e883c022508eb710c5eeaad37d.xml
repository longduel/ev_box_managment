        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    // Get the request from RITM
    var grReq = new GlideRecord('sc_request');
    grReq.addQuery('sys_id', current.request);
    grReq.query();

    if (grReq.next()) {
        if (current.state == 3) {
            grReq.request_state = 'closed_complete';
            grReq.update();
        } else if (current.state == 4) {
            grReq.request_state = 'closed_incomplete';
            grReq.update();
        }
    }

})(current, previous);]]></script>
