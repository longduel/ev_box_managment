        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    var payloadTemp;
    var resultTemp;

    // Change payload XML output to JSON
    var jsObj = gs.xmlToJSON(current.payload);
    var check = jsObj.results.result[0].updateResult;

    // Check if the update was sucefull in the JSON output
    if (JSUtil.nil(check)) {
        payloadTemp = jsObj.results.error;
        resultTemp = 'Failure';
    } else {
        payloadTemp = check;
        resultTemp = 'Success';
    }

    //Create new record for the DB connection
    var logs = new GlideRecord("u_ev_db_logs");
    logs.initialize();
    logs.sys_created_on = current.sys_created_on;
    logs.u_payload = payloadTemp;
    logs.u_result = resultTemp;
    logs.insert();

})(current, previous);]]></script>
