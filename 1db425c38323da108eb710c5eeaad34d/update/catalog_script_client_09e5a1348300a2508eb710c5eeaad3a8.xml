        <name>EV Check Open Incidents</name>
        <order/>
        <published_ref/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
    var ciSys_id = g_form.getValue('cmdb_ci');

    var plugDetails = new GlideAjax('AJAXUtils');
    plugDetails.addParam('sysparm_name', 'checkOpenIncidents');
    plugDetails.addParam('sysparm_sys_id', ciSys_id);
    plugDetails.getXMLAnswer(incidentCheck);

    function incidentCheck(response) {
        if (response) {
            var parsedData = JSON.parse(response);
            var incidentNumber = parsedData.incident_number;
            g_form.setValue('cmdb_ci', '');
            g_form.addErrorMessage('An Incident (' + incidentNumber + ') has already been created for this Configuration Item.', 'error');
        }
    }
}]]></script>
