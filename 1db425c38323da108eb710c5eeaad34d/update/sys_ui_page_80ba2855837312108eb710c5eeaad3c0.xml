        <name>diagnostic_page</name>
        <processing_script><![CDATA[// Get choice value from the Modal
function createDiagnostic(deviceSysId, result) {
    var createDiagnostic = new GlideRecord('u_ev_diagnostic');
    createDiagnostic.initialize();
    createDiagnostic.u_ev_box = deviceSysId;
    createDiagnostic.u_result = result;
    createDiagnostic.u_origin = 'server_diagnostic';
    createDiagnostic.u_proccessed = false;
    createDiagnostic.insert();
}

var result;
var diagChoice = request.getParameter('diagnostic_choice');
var reDirectionId = request.getParameter('system_id');

//Return either 1 for success table or 2 for fauilre table
var choiceNumber = Math.floor(Math.random() * 2) + 1;
var tableName;
if (choiceNumber == 1) {
    tableName = 'ev_diagnostic_1';
    result = 'Success';
} else if (choiceNumber == 2) {
    tableName = 'ev_diagnostic_2';
    result = 'Failure';
}

// Get a specific MID Server
var mid = new GlideRecord("ecc_agent");
mid.get('f4c9c83183e316108eb710c5eeaad369');
mid.query();

//Create a JDBC Probe and retive a diagnostic record
var j = new JDBCProbe(mid.name);
j.setDataSource('8d2765478323da108eb710c5eeaad306');
j.setTable(tableName);
j.setFunction("select");
j.setWhereClause("Operation=" + "'" + diagChoice + "'");
j.create();

createDiagnostic(reDirectionId, result);

var url = 'u_ev_devices.do?sys_id=' + reDirectionId;
response.sendRedirect(url);]]></processing_script>
