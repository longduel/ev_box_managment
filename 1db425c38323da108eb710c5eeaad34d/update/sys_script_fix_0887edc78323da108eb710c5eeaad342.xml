    <sys_script_fix action="INSERT_OR_UPDATE">
        <before>false</before>
        <description/>
        <name>DB Connection</name>
        <record_for_rollback>true</record_for_rollback>
        <script><![CDATA[// Get a specific MID Server
var mid = new GlideRecord("ecc_agent");
mid.addQuery('name','EVDevicesServer');
mid.query();
mid.next();

// Get a specific Data Source
var ds = new GlideRecord("sys_data_source");
ds.addQuery('name','EV DataBase');
ds.query();
ds.next();

gs.log(mid.name + ds.name);

//Create a JDBC Probe and insert three rows (one will be updated and one deleted later on...)
var j = new JDBCProbe(mid.name);
j.setDataSource(ds.sys_id);
j.setTable("test");
j.setFunction("update");
j.addField("voltage", "222");
j.setWhereClause("Indentifier='EVOP1'");
j.create();]]></script>
